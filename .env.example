# ─────────────────────────────────────────────────────────────
# Base44 + Vite build-time environment variables
# All VITE_* vars are inlined into the JS bundle at BUILD time.
# Changing any value requires a REBUILD (not a redeploy).
# ─────────────────────────────────────────────────────────────

# Required — your Base44 application ID (found in Base44 dashboard)
VITE_BASE44_APP_ID=your_base44_app_id_here

# Optional — pin a specific backend functions version (leave blank for latest)
VITE_BASE44_FUNCTIONS_VERSION=

# Optional — the public URL where this frontend will be served
# Must match the domain configured in Base44 for auth redirects
# Example: https://ncos.example.com  (NO trailing slash)
VITE_BASE44_APP_BASE_URL=https://your-domain.ondigitalocean.app